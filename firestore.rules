rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: cada uno puede leer todos, pero solo escribir su propio documento
    match /hogar_usuarios/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin()
      );
      // Solo admin puede borrar usuarios
      allow delete: if isAdmin();
    }

    // Historial: cualquier autenticado puede leer, crear sus propias entradas
    match /hogar_historial/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Verificar/rechazar: solo hermanos (no el propio) o admin
      // Hermanos solo pueden cambiar estado (no puntos ni otros campos)
      allow update: if request.auth != null && (
        (resource.data.usuarioId != request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])) ||
        isAdmin()
      );
      // Borrar: solo admin o el propio usuario
      allow delete: if request.auth != null && (
        resource.data.usuarioId == request.auth.uid ||
        isAdmin()
      );
    }

    // Lista de la compra: todos pueden leer/escribir
    match /hogar_lista_compra/{docId} {
      allow read, write: if request.auth != null;
    }

    // Tareas custom: solo admin puede escribir, todos leen
    match /hogar_tareas_custom/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Config (tareas ocultas): solo admin puede escribir, todos leen
    match /hogar_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Función helper para verificar si el usuario es admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/hogar_usuarios/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
